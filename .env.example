# === Бригадир.Про — переменные окружения ===
# Скопируйте этот файл в .env и заполните реальными значениями.
# Никогда не коммитьте .env в Git (см. .gitignore).

# --- Django ---
SECRET_KEY=change-me-to-a-random-50-char-string
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=

# --- База данных ---
# Локально можно не задавать — используется SQLite по умолчанию.
# В проде (Yandex Cloud / Timeweb, PostgreSQL 15+):
# DATABASE_URL=postgres://user:password@host:5432/brigadir_pro
DATABASE_URL=

# --- Email (SMTP) ---
# По умолчанию письма выводятся в консоль (EmailBackend=console).
# В проде задать SMTP-хостинга или сервиса рассылки.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@brigadir.pro

# --- ЮKassa (раздел 6.1 ТЗ) ---
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_TEST_MODE=True

# --- Безопасность (прод) ---
SECURE_SSL_REDIRECT=True

# === Модули Addendum №1/№2 ===
# Все ключи ниже необязательны: без них модули работают в ДЕМО-режиме
# (как ЮKassa). Впишите реальные ключи — включится боевая интеграция.

# AI-ассистент прораба (Модуль J, раздел 6.8)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# СМС для ПЭП (Модуль I) — напр. SMS.ru
SMS_API_KEY=

# ФНС «Мой налог» — чеки (Модуль D)
FNS_API_KEY=

# Проверка контрагентов — Контур/СПАРК (Модуль E)
KONTUR_API_KEY=

# Мессенджеры (Модуль F): WhatsApp через Wazzup + Telegram-бот
WHATSAPP_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=brigadirpro_bot

# Голос (Модуль H): основной ввод — браузерный Web Speech (бесплатно, без ключа).
# Серверное распознавание — опционально:
# OPENAI_API_KEY=               (Whisper)
# YANDEX_SPEECHKIT_API_KEY=     (альтернатива)

# Push-уведомления
# FCM_SERVER_KEY=
