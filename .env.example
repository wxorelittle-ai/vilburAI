# === Бригадир.Про — переменные окружения ===
# Скопируйте этот файл в .env и заполните реальными значениями.
# Никогда не коммитьте .env в Git (см. .gitignore).

# --- Django ---
SECRET_KEY=change-me-to-a-random-50-char-string
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=

# --- База данных ---
# Локально можно не задавать — используется SQLite по умолчанию.
# В проде (Yandex Cloud / Timeweb, PostgreSQL 15+):
# DATABASE_URL=postgres://user:password@host:5432/brigadir_pro
DATABASE_URL=

# --- Email (SMTP) ---
# По умолчанию письма выводятся в консоль (EmailBackend=console).
# В проде задать SMTP-хостинга или сервиса рассылки.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@brigadir.pro

# --- ЮKassa (раздел 6.1 ТЗ) ---
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_TEST_MODE=True

# --- Безопасность (прод) ---
SECURE_SSL_REDIRECT=True

# --- AI-ассистент прораба (Модуль J, раздел 6.8 ТЗ) ---
# Без ключа Модуль J работает в демо-режиме (локальная сводка).
# С ключом — реальный вызов Anthropic API.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Далее будут добавлены по мере подключения модулей ---
# TELEGRAM_BOT_TOKEN=            (Модуль F, Addendum №1)
# WHATSAPP_API_KEY=              (Модуль F, Addendum №1)
# FNS_MOI_NALOG_TOKEN=           (Модуль D, Addendum №1)
# KONTUR_FOCUS_API_KEY=          (Модуль E, Addendum №1)
# OPENAI_API_KEY=                (Модуль H — Whisper, Addendum №1)
# YANDEX_SPEECHKIT_API_KEY=      (Модуль H — альтернатива Whisper)
# FCM_SERVER_KEY=                (Push-уведомления)
